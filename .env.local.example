# Copie este arquivo para .env.local e preencha com suas credenciais do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Service role key (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Email do criador do TiBum (acessa /super-admin)
SUPER_ADMIN_EMAIL=seu-email@exemplo.com
