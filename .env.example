# ============================================
# TiBum SaaS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# NUNCA commite o arquivo .env.local
# ============================================

# Supabase (obtenha em: Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Service Role Key — usada apenas no servidor para o painel super admin
# Encontre em: Supabase Dashboard → Settings → API → service_role (secret)
# ATENÇÃO: nunca exponha esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ── Super Admin TiBum ─────────────────────────
# Email da conta Supabase do criador — acessa /super-admin
SUPER_ADMIN_EMAIL=seu-email@exemplo.com

# ── Futuro: Stripe (billing) ─────────────────
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Futuro: WhatsApp (notificações) ──────────
# WHATSAPP_API_URL=https://api.z-api.io/...
# WHATSAPP_API_TOKEN=seu-token
